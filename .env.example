# =============================================================================
# Variáveis de ambiente — Gestão de Fila Fonoaudiologia
# =============================================================================
# Copie este arquivo para `.env` e preencha com as credenciais do seu projeto
# Supabase. NUNCA faça commit do arquivo `.env` (ele está no .gitignore).
#
# Onde encontrar: painel do Supabase > Project Settings > Data API / API Keys
# -----------------------------------------------------------------------------

# URL do projeto Supabase (ex.: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Chave pública "anon" (publishable) do Supabase
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Observações:
# - Sem estas variáveis, o app funciona em "Modo Local" (apenas localStorage,
#   sem sincronização entre dispositivos).
# - Com elas configuradas, os dados são salvos no Supabase e sincronizados em
#   tempo real entre todos os desktops que acessam o app ("Sincronizado").
# - No deploy da Vercel, cadastre as duas variáveis em
#   Project Settings > Environment Variables.
# =============================================================================
